<?xml version="1.0"?>
<robot name="first_robot">
    <!--机器人的身体部分-->
    <link name="base_link">
    <!--部件的外观描述-->
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <!--几何形状-->
            <geometry>
                <!--圆柱体radius半径0.1 高度0.2m-->
                <cylinder radius="0.1" length="0.2"/>
            </geometry>
            <!--材质和颜色描述-->
            <material name="white">
                <color rgba="1.0 1.0 1.0 0.5"/>
            </material>
        </visual>
    </link>

    <!--机器人的IMU部件，惯性测量传感器-->
    <link name="imu_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
            <material name="blue">
                <color rgba="0.0 0.0 1.0 0.5"/>
            </material>
        </visual>
    </link>

    <!--连接身体和IMU的关节-->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0 0.0 0.03" rpy="0.0 0.0 0.0"/>
    </joint>
</robot>

